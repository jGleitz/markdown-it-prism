{
  "compilerOptions": {
    "target": "esnext",
    "module": "commonjs",
    "moduleResolution": "bundler",
    "types": [
      "jest",
      "node"
    ],
    "allowJs": false,
    "noEmit": true,
    "strict": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "typeRoots": [
      "types",
      "node_modules/@types"
    ]
  }
}